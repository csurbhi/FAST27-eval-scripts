; fio-rand-write.job for fiotest
[random-writers]
name=fio-rand-write
; Use cmr drive
filename=/dev/sda
numjobs=1
bs=4K
blockalign=4K
io_size=10G
ioengine=libaio
iodepth=1024
iodepth_batch=128
direct=1
readwrite=randwrite
; uniform random writes
random_distribution=random
write_bw_log=./bw_log_avg
write_lat_log=./lat_log_avg
write_iops_log=./iops_log_avg
