; fio-rand-write.job for fiotest
[random-writers]
name=fio-rand-write
; Use host aware drive's stl
filename=/dev/sda
numjobs=1
bs=1M
blockalign=1M
io_size=45G
direct=1
ioengine=libaio
iodepth=64
iodepth_batch=32
readwrite=randwrite
; 70/30 LBA
random_distribution=zipf:0.76878
write_bw_log=./bw_log_avg
write_lat_log=./lat_log_avg
write_iops_log=./iops_log_avg
